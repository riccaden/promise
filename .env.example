# =============================================================================
# .env.example – Vorlage für Environment Variables (Oblivio)
# Diese Datei enthält KEINE echten Zugangsdaten – nur Platzhalter.
# Die tatsächlichen Werte werden im Railway Dashboard unter "Variables" gesetzt.
# Kopiere diese Datei als .env und trage die korrekten Werte ein.
# =============================================================================

# === Database Configuration (Supabase PostgreSQL) ===
# Verbindungs-URL zur Supabase-Datenbank – enthält Host, Port, User und Passwort
# Supabase verwendet den Supavisor Connection Pooler (pooler.supabase.com)
# Option 1: Verwende DATABASE_URL (empfohlen für Railway)
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT]:yourpassword@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Option 2: Oder verwende einzelne Connection Details
# Spring Boot kann die Verbindung auch über separate Properties konfigurieren
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres.[YOUR-PROJECT]
# SPRING_DATASOURCE_PASSWORD=yourpassword

# === OpenAI Configuration ===
# API-Key für OpenAI GPT-4o – wird vom PROMISE Framework für KI-Konversationen verwendet
# Erstelle einen Key unter https://platform.openai.com/api-keys
OPENAI_KEY=sk-proj-your-openai-api-key-here

# === Server Configuration ===
# Railway setzt die PORT-Variable automatisch – manuelles Setzen normalerweise nicht nötig
# PORT=8080

# === Optional: Spring Profile ===
# Aktiviert das Production-Profil (andere DB-Konfiguration, reduziertes Logging)
# Wird im Dockerfile bereits via -Dspring.profiles.active=prod gesetzt
# SPRING_PROFILES_ACTIVE=prod
